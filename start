#!/bin/bash

set -e

seed_database=false
use_docker=false
run_journey_tests=false
run_journey_tests_with_browserstack=false
run_performance_tests=false

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --docker)
      use_docker=true
      ;;
    -jt|--journey-tests)
      run_journey_tests=true
      ;;
    -jt-b|--journey-test-browserstack)
      run_journey_tests_with_browserstack=true
      ;;
    -pt|--performance-tests)
      run_performance_tests=true
      ;;
    -s|--seed)
      seed_database=true
      ;;
    *)
      echo "Unknown option: $1"
      echo "Valid options:"
      echo "  --docker                                            Run all apps in Docker (default: host-native)"
      echo "  -s or --seed                                        Seed backend PostgreSQL database with fake data"
      echo "  -jt or --journey-tests                              Trigger local test run of journey test suite"
      echo "  -pt or --performance-tests                          Trigger local test run of performance test suite"
      echo "  -jt -pt or --journey-tests --performance-tests      Trigger local test run of all test suites"
      exit 1
      ;;
  esac
  shift
done

projectRoot="$(a="/$0"; a=${a%/*}; a=${a:-.}; a=${a#/}/; cd "$a/.." || return; pwd)"

if [ "$use_docker" = true ]; then
  cd "${projectRoot}"
  cd ./fcp-mpdp-backend && \
    docker compose --profile app up -d

  cd "${projectRoot}"
  cd ./fcp-mpdp-frontend && \
    docker compose --profile app up -d

  cd "${projectRoot}"
  cd ./fcp-mpdp-admin && \
    docker compose --profile app up -d

  if [ "$seed_database" = true ]; then
    cd "${projectRoot}"
    ./fcp-mpdp-core/seed --docker
  fi
else
  if [ "$seed_database" = true ]; then
    # Ensure Postgres is up before seeding (each app starts its own deps via npm run local)
    cd "${projectRoot}"
    cd ./fcp-mpdp-backend && docker compose up -d
    cd "${projectRoot}"
    ./fcp-mpdp-core/seed
  fi

  echo ""
  echo "To start the apps host-native:"
  echo ""
  echo "  1. Open the workspace:  code ${projectRoot}/fcp-mpdp-core/fcp-mpdp.code-workspace"
  echo "  2. Run the task:        Ctrl+Shift+P > Tasks: Run Task > Local: Start all"
  echo ""
  echo "Each app manages its own dependency containers via npm run local."
  echo ""
fi

if [ "$seed_database" = true ] && { [ "$run_journey_tests" = true ] || [ "$run_journey_tests_with_browserstack" = true ]; }; then
  echo "Waiting for search cache to warm..."
  for i in $(seq 1 15); do
    COUNT=$(curl -sf "http://localhost:3001/v1/payments/search?searchString=Sons" 2>/dev/null | grep -o '"count":[0-9]*' | grep -o '[0-9]*')
    if [ -n "$COUNT" ] && [ "$COUNT" -gt 0 ]; then
      echo "Search cache ready ($COUNT results)"
      break
    fi
    sleep 1
  done
fi

if [ "$run_journey_tests" = true ]; then
  echo "Starting fcp-mpdp-journey-test-suite..."
  cd "${projectRoot}"
  cd ./fcp-mpdp-journey-test-suite && \
  echo "Running journey tests (Playwright only)..."
  docker compose build
  npm run docker:test:local
fi

if [ "$run_journey_tests_with_browserstack" = true ]; then
  echo "Starting fcp-mpdp-journey-test-suite..."
  cd "${projectRoot}"
  cd ./fcp-mpdp-journey-test-suite && \
  echo "Running journey tests (Playwright + BrowserStack)..."
  docker compose build
  npm run docker:test:local:browserstack
fi

if [ "$run_performance_tests" = true ]; then
  echo "Starting fcp-mpdp-performance-test-suite..."
  cd "${projectRoot}"
  cd ./fcp-mpdp-performance-test-suite && \
  echo "Running performance tests..."
  ./test.sh
fi
